<!DOCTYPE html>
<html lang="tr">
<head>
  <%- include('../partials/head') %>
</head>
<body class="app-body">
  <%- include('../partials/nav', { active: 'deliveries' }) %>
  <main class="app-main narrow">
    <h1 class="page-title"><%= item && item._id ? 'Teslimat düzenle' : 'Teslimat ekle' %></h1>
    <% if (item && item.deliveryCode) { %><p class="hint-banner">Kod: <strong><%= item.deliveryCode %></strong></p><% } %>
    <% if (error) { %><p class="form-error"><%= error %></p><% } %>
    <% const action = item && item._id ? '/deliveries/' + item._id + '?_method=PUT' : '/deliveries'; %>
    <form method="post" action="<%= action %>" class="form-card card-elevated form-stack">
      <label>Müşteri *
        <select name="client" required>
          <% clients.forEach(c => { %>
          <option value="<%= c._id %>" <%= item && String(item.client) === String(c._id) ? 'selected' : '' %>><%= c.name %></option>
          <% }) %>
        </select>
      </label>
      <label>İş günlüğü kaydı *
        <select name="workLog" required>
          <% workLogs.forEach(w => { %>
          <option value="<%= w._id %>" <%= item && String(item.workLog) === String(w._id) ? 'selected' : '' %>><%= w.workCode %> — <%= w.client ? w.client.name : '' %> <%= w.projectName ? '('+w.projectName+')' : '' %></option>
          <% }) %>
        </select>
      </label>
      <label>Aktivite türü<input type="text" name="activityType" value="<%= item ? item.activityType||'' : '' %>" /></label>
      <label>Proje<input type="text" name="projectName" value="<%= item ? item.projectName||'' : '' %>" /></label>
      <label>Teslim türü
        <select name="deliveryType">
          <option value="">—</option>
          <option value="Sosyal Medya" <%= item && item.deliveryType==='Sosyal Medya' ? 'selected' : '' %>>Sosyal Medya</option>
          <option value="Konvansiyonel" <%= item && item.deliveryType==='Konvansiyonel' ? 'selected' : '' %>>Konvansiyonel</option>
          <option value="Diğer" <%= item && item.deliveryType==='Diğer' ? 'selected' : '' %>>Diğer</option>
        </select>
      </label>
      <label>Başlık<input type="text" name="title" value="<%= item ? item.title||'' : '' %>" /></label>
      <label>Sorumlu<input type="text" name="responsiblePerson" value="<%= item ? item.responsiblePerson||'' : '' %>" /></label>
      <label>Oluşturma tarihi<input type="date" name="createdOn" value="<%= item && item.createdOn ? new Date(item.createdOn).toISOString().slice(0,10) : new Date().toISOString().slice(0,10) %>" /></label>
      <label>Teslim tarihi<input type="date" name="deliveryDate" value="<%= item && item.deliveryDate ? new Date(item.deliveryDate).toISOString().slice(0,10) : '' %>" /></label>
      <label>Durum
        <select name="status">
          <% ['Hazırlanıyor','Bekliyor','Revizede','Onaylandı','Tamamlandı','Teslim Edildi','Devam Ediyor'].forEach(s => { %>
          <option value="<%= s %>" <%= item && item.status===s ? 'selected' : (!item && s==='Hazırlanıyor' ? 'selected' : '') %>><%= s %></option>
          <% }) %>
        </select>
      </label>
      <label>Açıklama<textarea name="description" rows="2"><%= item ? item.description||'' : '' %></textarea></label>
      <fieldset class="form-fieldset">
        <legend>Sosyal medya (opsiyonel)</legend>
        <label>Platform<input type="text" name="platform" placeholder="Instagram, YouTube..." value="<%= item ? item.platform||'' : '' %>" /></label>
        <label>Gönderi türü<input type="text" name="postType" placeholder="Reels, Post..." value="<%= item ? item.postType||'' : '' %>" /></label>
        <div class="grid-2">
          <label>Etkileşim<input type="number" name="interaction" value="<%= item && item.interaction!=null ? item.interaction : '' %>" /></label>
          <label>Görüntülenme<input type="number" name="views" value="<%= item && item.views!=null ? item.views : '' %>" /></label>
          <label>Beğeni<input type="number" name="likes" value="<%= item && item.likes!=null ? item.likes : '' %>" /></label>
          <label>Yorum<input type="number" name="comments" value="<%= item && item.comments!=null ? item.comments : '' %>" /></label>
          <label>Paylaşım<input type="number" name="shares" value="<%= item && item.shares!=null ? item.shares : '' %>" /></label>
        </div>
      </fieldset>
      <div class="form-actions">
        <a href="/deliveries" class="btn-ghost">İptal</a>
        <button type="submit" class="btn-primary">Kaydet</button>
      </div>
    </form>
  </main>
  <%- include('../partials/foot') %>
</body>
</html>
